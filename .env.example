# ConnectMulti proxy keys live in .env.local.
# Do not commit real API keys or ingest secrets.

# Optional local token stats file. Defaults to .usage-stats.json.
# USAGE_STATS_JSON_PATH=.usage-stats.json

# New API usage ingest. Keep disabled unless a New API instance with
# POST /api/usage/ingest is running.
NEWAPI_INGEST_ENABLED=false
NEWAPI_INGEST_URL=http://127.0.0.1:11002/api/usage/ingest
NEWAPI_INGEST_SECRET=replace-with-a-private-secret
NEWAPI_INGEST_USER_ID=2
